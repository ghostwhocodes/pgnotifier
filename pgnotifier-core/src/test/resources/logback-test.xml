<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="org.testcontainers" level="ERROR"/>
    <logger name="com.github.dockerjava" level="ERROR"/>

    <logger name="pgnotifier.Wal2JsonChangeEventDecoder" level="OFF"/>
    <logger name="pgnotifier.internal.replication.BatchReplicationWorker" level="OFF"/>
    <logger name="pgnotifier.internal.replication.ReplicationSlot" level="OFF"/>
    <logger name="pgnotifier.util.JdbcUtil" level="OFF"/>
    <logger name="pgnotifier.util.LatchedProcess" level="OFF"/>

    <root level="ERROR">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
